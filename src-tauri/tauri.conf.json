{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TermiNAL",
  "version": "0.1.0",
  "identifier": "dev.terminal.tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TermiNAL",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "backgroundColor": "#1a1b26"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
